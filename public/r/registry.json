{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "useful-artifacts",
  "homepage": "https://github.com/esfredderickmx/useful-artifacts",
  "items": [
    {
      "name": "use-decorator",
      "type": "registry:hook",
      "title": "useDecorator",
      "description": "A typed helper hook for selecting decoration metadata by value.",
      "dependencies": ["@phosphor-icons/react"],
      "files": [
        {
          "path": "registry/react/hooks/use-decorator.ts",
          "type": "registry:hook"
        },
        {
          "path": "registry/react/types/decoration.ts",
          "type": "registry:file",
          "target": "resources/js/types/decoration.ts"
        }
      ]
    },
    {
      "name": "drop-schemas",
      "type": "registry:file",
      "title": "DropSchemas Artisan Command",
      "description": "A local-only Artisan command for dropping non-system PostgreSQL schemas on local and phpunit testing databases.",
      "files": [
        {
          "path": "registry/laravel/app/Console/Commands/DropSchemas.php",
          "type": "registry:file",
          "target": "app/Console/Commands/DropSchemas.php"
        }
      ]
    },
    {
      "name": "app-exception",
      "type": "registry:file",
      "title": "AppException",
      "description": "Lets custom exceptions extend AppException to flash translatable alert or toast messages with a specific emphasis variant. Requires InertiaNotify::declare() in the boot method of a registered service provider because the shadcn CLI cannot register the macro.",
      "files": [
        {
          "path": "registry/laravel/app/Exceptions/AppException.php",
          "type": "registry:file",
          "target": "app/Exceptions/AppException.php"
        },
        {
          "path": "registry/laravel/app/Macros/InertiaNotify.php",
          "type": "registry:file",
          "target": "app/Macros/InertiaNotify.php"
        },
        {
          "path": "registry/laravel/app/Enums/EmphasisVariant.php",
          "type": "registry:file",
          "target": "app/Enums/EmphasisVariant.php"
        },
        {
          "path": "registry/laravel/app/Enums/FlashResponse.php",
          "type": "registry:file",
          "target": "app/Enums/FlashResponse.php"
        }
      ]
    },
    {
