    {
      "name": "emphasis-colors-simple",
      "type": "registry:theme",
      "title": "Emphasis Colors (Simple)",
      "description": "A lightweight semantic emphasis color layer that adds affirmative, informative, preventive, and interrogative tokens without replacing destructive.",
