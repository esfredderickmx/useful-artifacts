{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "useful-artifacts",
  "homepage": "https://example.com/useful-artifacts",
  "items": [
    {
      "name": "use-decorator",
      "type": "registry:hook",
      "title": "useDecorator",
      "description": "A typed helper hook for selecting decoration metadata by value.",
      "dependencies": ["@phosphor-icons/react"],
      "files": [
        {
          "path": "registry/react/hooks/use-decorator.ts",
          "type": "registry:hook"
        },
        {
          "path": "registry/react/types/decoration.ts",
          "type": "registry:file",
          "target": "resources/js/types/decoration.ts"
        }
      ]
    },
    {
      "name": "drop-schemas",
      "type": "registry:file",
      "title": "DropSchemas Artisan Command",
      "description": "A local-only Artisan command for dropping non-system PostgreSQL schemas on local and phpunit testing databases.",
      "files": [
        {
          "path": "registry/laravel/app/Console/Commands/DropSchemas.php",
          "type": "registry:file",
          "target": "app/Console/Commands/DropSchemas.php"
        }
      ]
    }
  ]
}
